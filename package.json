{
  "name": "@yalla/typography-rules",
  "version": "0.0.1",
  "description": "Your package description here",
  "license": "MIT",
  "author": "Yalla Nkardaz",
  "repository": {
    "type": "git",
    "url": "https://github.com/DemerNkardaz/typography-rules"
  },
  "homepage": "https://github.com/DemerNkardaz/typography-rules#readme",
  "bugs": {
    "url": "https://github.com/DemerNkardaz/typography-rules/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "prepublishOnly": "npm run build && npm run lint && npm run type-check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
